// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  candidate
  admin
}

enum QuestionType {
  technical
  behavioral
  coding
  system_design
}

enum Difficulty {
  easy
  medium
  hard
}

enum InterviewStatus {
  created
  in_progress
  completed
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String    @map("password_hash")
  fullName     String    @map("full_name")
  role         UserRole  @default(candidate)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  resumes    Resume[]
  interviews Interview[]

  @@map("users")
}

model Resume {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  fileName   String   @map("file_name")
  fileUrl    String   @map("file_url")
  parsedText String?  @map("parsed_text") @db.Text
  parsedData Json?    @map("parsed_data")
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resumes")
}

model Question {
  id             String       @id @default(uuid()) @db.Uuid
  title          String
  description    String       @db.Text
  type           QuestionType
  difficulty     Difficulty
  tags           String[]
  expectedAnswer String?      @map("expected_answer") @db.Text
  timeLimitSecs  Int          @default(120) @map("time_limit_secs")
  metadata       Json?
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  interviewQuestions InterviewQuestion[]

  @@map("questions")
}

model Interview {
  id             String          @id @default(uuid()) @db.Uuid
  candidateId    String?         @map("candidate_id") @db.Uuid
  title          String
  jobDescription String?         @map("job_description") @db.Text
  jobRole        String          @map("job_role")
  status         InterviewStatus @default(created)
  startedAt      DateTime?       @map("started_at")
  completedAt    DateTime?       @map("completed_at")
  metadata       Json?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  candidate          User?               @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  interviewQuestions InterviewQuestion[]
  result             InterviewResult?

  @@map("interviews")
}

model InterviewQuestion {
  id          String   @id @default(uuid()) @db.Uuid
  interviewId String   @map("interview_id") @db.Uuid
  questionId  String   @map("question_id") @db.Uuid
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  question  Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer    Answer?

  @@unique([interviewId, questionId])
  @@map("interview_questions")
}

model Answer {
  id                  String    @id @default(uuid()) @db.Uuid
  interviewQuestionId String    @unique @map("interview_question_id") @db.Uuid
  answerText          String?   @map("answer_text") @db.Text
  answerAudioUrl      String?   @map("answer_audio_url")
  timeTakenSecs       Int?      @map("time_taken_secs")
  submittedAt         DateTime  @default(now()) @map("submitted_at")
  metadata            Json?

  interviewQuestion InterviewQuestion @relation(fields: [interviewQuestionId], references: [id], onDelete: Cascade)
  score             Score?

  @@map("answers")
}

model Score {
  id            String   @id @default(uuid()) @db.Uuid
  answerId      String   @unique @map("answer_id") @db.Uuid
  bertScore     Float?   @map("bert_score")
  semanticScore Float?   @map("semantic_score")
  keywordScore  Float?   @map("keyword_score")
  llmScore      Float?   @map("llm_score")
  overallScore  Float    @map("overall_score")
  feedback      String?  @db.Text
  criteria      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  answer Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)

  @@map("scores")
}

model InterviewResult {
  id             String   @id @default(uuid()) @db.Uuid
  interviewId    String   @unique @map("interview_id") @db.Uuid
  overallScore   Float    @map("overall_score")
  recommendation String?  @db.Text
  summary        String?  @db.Text
  strengths      Json?
  weaknesses     Json?
  scoreBreakdown Json?    @map("score_breakdown")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@map("interview_results")
}
